# Shared runtime
NODE_ENV=development
LOG_LEVEL=info
SERVICE_ROLE=arena
PORT=8080
DEMO_MODE=live
DEMO_STEP_DELAY_MS=600

# Private service authentication — replace locally; never commit real values
INTERNAL_AGENT_TOKEN=replace-with-at-least-24-random-characters
LOG_BRIDGE_TOKEN=replace-with-at-least-24-random-characters

# Compose service locations
ARENA_INTERNAL_URL=http://arena:8080
TARGET_V1_URL=http://target-v1:8081
TARGET_V2_URL=http://target-v2:8081
RED_AGENT_URL=http://red-agent:8091
WHITE_AGENT_URL=http://white-agent:8092
CONTROLLER_AGENT_URL=http://deploy-controller:8093

# Set only in the matching target container
TARGET_VERSION=v1

# Pomerium MCP routes and role-scoped service account JWTs
# Copy these two values from the Pomerium Zero Docker onboarding screen.
# Keep the real token only in .env; .env is gitignored.
POMERIUM_ZERO_TOKEN=replace-with-zero-cluster-token
POMERIUM_STARTER_DOMAIN=replace-with-starter-subdomain.pomerium.app

# Current scaffold variables. These are renamed to the recruiting actor names
# when the recruiting contract migration lands.
RED_MCP_URL=https://red-mcp.example.invalid/mcp
WHITE_MCP_URL=https://white-mcp.example.invalid/mcp
CONTROLLER_MCP_URL=https://controller-mcp.example.invalid/mcp
RED_POMERIUM_JWT=replace-with-red-service-account-jwt
WHITE_POMERIUM_JWT=replace-with-white-service-account-jwt
CONTROLLER_POMERIUM_JWT=replace-with-controller-service-account-jwt

# Bootstrap can use latest. Before MCP policy testing, replace this with the
# sponsor-confirmed MCP-capable image digest; MCP is currently experimental.
POMERIUM_IMAGE=pomerium/pomerium:latest
