# Shared runtime
NODE_ENV=development
LOG_LEVEL=info
SERVICE_ROLE=arena
PORT=8080
DEMO_MODE=fake
DEMO_STEP_DELAY_MS=600

# Private service authentication — replace locally; never commit real values
INTERNAL_AGENT_TOKEN=replace-with-at-least-24-random-characters
LOG_BRIDGE_TOKEN=replace-with-at-least-24-random-characters

# Internal recruiting services
ARENA_INTERNAL_URL=http://arena:8080
RECRUITING_MCP_INTERNAL_URL=http://recruiting-mcp:8084/mcp

# Pomerium Zero data plane bootstrap
# Keep real values only in .env; .env is gitignored.
POMERIUM_ZERO_TOKEN=replace-with-zero-cluster-token
POMERIUM_STARTER_DOMAIN=replace-with-starter-subdomain.pomerium.app

# Identity-scoped MCP routes and service-account JWTs
SOURCER_MCP_URL=https://sourcer-mcp.example.invalid/mcp
VERIFIER_MCP_URL=https://verifier-mcp.example.invalid/mcp
CONTROLLER_MCP_URL=https://controller-mcp.example.invalid/mcp
SOURCER_POMERIUM_JWT=replace-with-sourcer-service-account-jwt
VERIFIER_POMERIUM_JWT=replace-with-verifier-service-account-jwt
CONTROLLER_POMERIUM_JWT=replace-with-controller-service-account-jwt

# Pin the sponsor-confirmed MCP-capable image digest before judging.
POMERIUM_IMAGE=pomerium/pomerium:latest
